# 本文件为模板，可提交；实际密钥请写在 .env（已忽略，不提交）
# 必填：在 https://openrouter.ai/keys 申请
OPENROUTER_API_KEY=

# 服务监听端口
PORT=10300

# 国内机器访问 OpenRouter 时使用的 HTTP 代理（可选）
# HTTP_PROXY=http://127.0.0.1:7890

# 自动模式使用的模型 ID：请求里写这个会按响应速度在免费模型中切换
# AUTO_MODEL_ID=openrouter/auto

# 参与自动切换的免费模型列表，逗号分隔；不填则从 OpenRouter API 自动拉取最新免费模型（推荐）
# OPENROUTER_FREE_MODELS=openrouter/free,stepfun/step-3.5-flash:free

# 是否从 OpenRouter 拉取免费模型列表（未设置 OPENROUTER_FREE_MODELS 时生效），默认 true
# FETCH_FREE_MODELS_FROM_OPENROUTER=false

# 是否启用延迟统计（用于自动选最快模型），默认 true
# ENABLE_LATENCY_TRACKING=true

# 单模型最大响应时间（毫秒），超时则自动切换模型重试，默认 1000
# MODEL_TIMEOUT_MS=1000
